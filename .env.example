# Sao chép thành .env ở gốc repo:  npm run setup:env
# (hoặc tự copy). File .env không commit.

# Cổng Express API — KHÔNG dùng tên PORT ở đây: CRA dùng PORT cho dev server React.
SERVER_PORT=8080

# Dev: proxy CRA trỏ tới API (khớp SERVER_PORT).
REACT_APP_PROXY_TARGET=http://localhost:8080

# Prod / gọi API host khác. Để trống khi SPA và API cùng origin.
# REACT_APP_API_BASE_URL=

# Gửi cookie với fetch: include | omit
# REACT_APP_FETCH_CREDENTIALS=omit
